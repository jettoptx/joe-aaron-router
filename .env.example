# ─── AARON Router env vars (copy to .env or set in systemd EnvironmentFile) ───

# ── Existing (unchanged) ──
AARON_PORT=8888
SPACETIMEDB_URL=
SOLANA_RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_HELIUS_KEY
ALLOWED_ORIGINS=https://astroknots.space,https://jetoptics.ai,https://jettoptics.ai

# ── Donor reward stack (Phase 2 + 3a) ──

# Network selector. "mainnet" reads JTX_MINT_MAINNET + SOLANA_RPC_URL.
# "devnet"/"localnet" reads JTX_MINT_DEVNET + SOLANA_RPC_URL_DEVNET.
SOLANA_NETWORK=mainnet

# Token-2022 mint addresses for JTX. Mainnet is hard-coded as a fallback.
JTX_MINT_MAINNET=9XpJiKEYzq5yDo5pJzRfjSRMPL2yPfDQXgiN7uYtBhUj
JTX_MINT_DEVNET=

# Token-2022 always uses 9 decimals for JTX. Adjust only if mint changes.
JTX_DECIMALS=9

# Whole tokens dropped per donation. 1 = "thank-you" semantic.
JTX_DROP_AMOUNT=1

# Daily abuse circuit-breaker. Refuses further drops after this count
# until 24h rolls past. Set higher if you expect a viral moment.
JTX_DAILY_DROP_CAP=10000

# JOE agent signer keypair — sealed file, mode 0400, owner = systemd user.
# DO NOT commit. DO NOT log. Boot fails fast if perms aren't 0400.
JOE_AGENT_KEYPAIR_PATH=/etc/optx/joe-agent.json

# Devnet RPC (only used when SOLANA_NETWORK starts with "dev").
SOLANA_RPC_URL_DEVNET=https://devnet.helius-rpc.com/?api-key=YOUR_HELIUS_KEY

# jett-vault program ID (fixed across networks).
JETT_VAULT_PROGRAM_ID=JTX5uXTiZ1M3hJkjv5Cp5F8dr3Jc7nhJbQjCFmgEYA7

# Helius webhook HMAC secret. Generated at webhook-creation time on
# https://dashboard.helius.dev. Required for /donations/webhooks/helius.
HELIUS_WEBHOOK_SECRET=

# Sealed admin token for /donations/admin/replay/{tx_sig}.
ADMIN_TOKEN=

# SQLite path for idempotency + audit log. Parent dir is auto-created.
DONATIONS_DB_PATH=/var/lib/optx/donations.db

# ── Phase 1: Xahau cross-chain donor badge (optional until ready) ──
# Leave the SEED + HOOK_ACCOUNT empty to disable the Xahau leg cleanly —
# the JTX drop still runs.
XAHAU_RPC_URL=wss://xahau.network
XAHAU_FUNDING_SEED=
XAHAU_HOOK_ACCOUNT=
XAHAU_DONATION_AMOUNT_DROPS=5000000

# ── Vercel proxy gate (optional) ──
# If set, AARON expects this header on /donations/claim and /donations/status
# requests from the Vercel proxy. Prevents direct browser-side access.
# (Wire-up TODO if you decide to enforce — currently the router doesn't
# check it; see docs/donor-rewards-deploy.md.)
BACKEND_PROXY_TOKEN=
